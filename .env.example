# Saleor API URL (required) - keep the trailing slash
NEXT_PUBLIC_SALEOR_API_URL=https://your-instance.saleor.cloud/graphql/

# Storefront URL - set on production for correct canonical URLs and OG images
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000

# Checkout-only deploy (optional) — absolute checkout links from storefront and redirect allowlist
# NEXT_PUBLIC_CHECKOUT_URL=https://checkout.example.com

# Channel slug (required) - fallback when STOREFRONT_CHANNELS is not set
# The root "/" redirects to this channel (e.g., "/default-channel")
NEXT_PUBLIC_DEFAULT_CHANNEL=default-channel

# Storefront channel allowlist (recommended for multi-channel) — comma-separated slugs
# Only these channels get routes, cache invalidation, and footer selector entries.
# STOREFRONT_CHANNELS=us,uk,eu

# App token (optional) — required for footer currency selector metadata from Saleor
# SALEOR_APP_TOKEN=

# Opt-in: discover ALL active Saleor channels from API (not recommended when Saleor has many channels).
# Prefer STOREFRONT_CHANNELS instead. Requires SALEOR_APP_TOKEN.
# STOREFRONT_DISCOVER_CHANNELS=true

# Cache invalidation — use ≥32 character random strings in production
# Manual revalidation: GET /api/cache-info and GET /api/revalidate (Authorization: Bearer header)
# REVALIDATE_SECRET=
# Saleor webhook HMAC for POST /api/revalidate (Dashboard → Configuration → Webhooks)
# SALEOR_WEBHOOK_SECRET=

# Checkout — Dummy Payment (local/staging test orders)
# Enabled automatically in development. Set to true on cloud/staging to allow dummy checkout.
# ALLOW_DUMMY_PAYMENT=true
# NEXT_PUBLIC_ALLOW_DUMMY_PAYMENT=true

# Checkout — Stripe Elements (Saleor Stripe app)
# Required on cloud/staging (NODE_ENV=production). Auto-enabled in local development.
# Publishable keys come from Saleor paymentGatewayInitialize — configure Stripe in Saleor Dashboard.
# NEXT_PUBLIC_ENABLE_STRIPE_PAYMENTS=true
# ENABLE_STRIPE_PAYMENTS=true
# Express Checkout wallets (Apple Pay, Google Pay, Link) on payment step — on when Stripe is enabled.
# NEXT_PUBLIC_ENABLE_STRIPE_EXPRESS_CHECKOUT=false

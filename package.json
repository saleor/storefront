{
	"name": "saleor-storefront",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"license": "SEE LICENSE IN LICENSE",
	"scripts": {
		"dev": "next dev --webpack",
		"dev:webpack": "next dev --webpack",
		"dev:theme-editorial": "NEXT_PUBLIC_TYPOGRAPHY_THEME=editorial next dev --webpack",
		"dev:turbopack": "next dev",
		"build": "next build",
		"start": "next start",
		"predev": "pnpm run generate:all",
		"prebuild": "pnpm run generate:all",
		"pretypecheck": "pnpm run generate:all",
		"lint": "eslint",
		"lint:fix": "eslint --fix",
		"lint:design-tokens": "node scripts/check-design-tokens.mjs",
		"generate": "graphql-codegen --config .graphqlrc.ts",
		"generate:checkout": "graphql-codegen --config src/checkout/graphql/codegen.ts",
		"generate:all": "pnpm run generate && pnpm run generate:checkout",
		"test": "vitest",
		"test:run": "vitest run",
		"typecheck": "tsc --noEmit",
		"knip": "knip",
		"prepare": "husky install",
		"configurator:storefront-content:validate": "pnpm dlx @saleor/configurator validate --config config/saleor/storefront-content.config.yml",
		"configurator:storefront-content:plan": "sh scripts/configurator-storefront-content.sh plan",
		"configurator:storefront-content:deploy": "sh scripts/configurator-storefront-content.sh deploy",
		"configurator:storefront-content:drop": "node scripts/drop-storefront-models.mjs",
		"configurator:storefront-content:translations": "node scripts/deploy-storefront-translations.mjs",
		"configurator:storefront-content:reset": "node scripts/drop-storefront-models.mjs && sh scripts/configurator-storefront-content.sh deploy && sh scripts/configurator-storefront-content.sh deploy && node scripts/deploy-storefront-translations.mjs",
		"catalog:translations:fetch": "node scripts/fetch-catalog-translations.mjs",
		"catalog:translations:plan": "node scripts/deploy-catalog-translations.mjs --dry-run --fail-on-skip",
		"catalog:translations:deploy": "node scripts/deploy-catalog-translations.mjs --fail-on-skip",
		"content:verify-attribute-slugs": "node scripts/verify-storefront-attribute-slugs.mjs",
		"content:verify-seed": "vitest run src/lib/content/configurator-seed.sync.test.ts",
		"content:export-seed": "node scripts/export-storefront-content-seed.mjs",
		"skills:bootstrap": "node scripts/bootstrap-agent-skills.mjs"
	},
	"dependencies": {
		"@graphql-typed-document-node/core": "3.2.0",
		"@radix-ui/react-dialog": "1.1.15",
		"@radix-ui/react-dropdown-menu": "2.1.16",
		"@radix-ui/react-navigation-menu": "1.2.14",
		"@saleor/auth-sdk": "1.0.3",
		"@stripe/react-stripe-js": "6.6.0",
		"@stripe/stripe-js": "9.7.0",
		"@vercel/speed-insights": "1.3.1",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.0",
		"editorjs-html": "3.4.3",
		"embla-carousel-react": "8.6.0",
		"geist": "1.5.1",
		"graphql": "16.8.1",
		"graphql-tag": "2.12.6",
		"lodash-es": "4.17.21",
		"lucide-react": "0.358.0",
		"next": "16.2.6",
		"next-intl": "4.13.0",
		"react": "^19.1.2",
		"react-dom": "^19.1.2",
		"react-error-boundary": "4.0.13",
		"react-zoom-pan-pinch": "4.0.3",
		"server-only": "0.0.1",
		"sharp": "0.33.2",
		"tailwind-merge": "3.4.0",
		"tailwindcss-animate": "1.0.7",
		"ts-invariant": "0.10.3",
		"urql": "4.0.6",
		"xss": "1.0.15"
	},
	"devDependencies": {
		"@graphql-codegen/cli": "6.1.1",
		"@graphql-codegen/client-preset": "5.2.2",
		"@graphql-codegen/typescript": "5.0.7",
		"@graphql-codegen/typescript-operations": "5.0.7",
		"@graphql-codegen/typescript-urql": "4.0.1",
		"@next/env": "16.0.7",
		"@parcel/watcher": "2.3.0",
		"@tailwindcss/container-queries": "0.1.1",
		"@tailwindcss/forms": "0.5.7",
		"@tailwindcss/typography": "0.5.10",
		"@types/lodash-es": "4.17.12",
		"@types/node": "^24.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"autoprefixer": "10.4.23",
		"eslint": "9.39.1",
		"eslint-config-next": "16.0.7",
		"husky": "8.0.3",
		"knip": "5.41.1",
		"lint-staged": "15.1.0",
		"postcss": "8.5.6",
		"postcss-import": "16.1.0",
		"prettier": "3.1.1",
		"prettier-plugin-tailwindcss": "0.5.9",
		"schema-dts": "1.1.2",
		"tailwindcss": "3.4.19",
		"typescript": "5.3.3",
		"vitest": "4.0.17",
		"yaml": "2.9.0"
	},
	"resolutions": {
		"graphql": "16.8.1"
	},
	"pnpm": {
		"overrides": {
			"dset": ">=3.1.4",
			"micromatch": ">=4.0.8",
			"@babel/runtime": ">=7.26.10",
			"@babel/helpers": ">=7.26.10",
			"brace-expansion@>=2": ">=2.0.2"
		}
	},
	"packageManager": "pnpm@10.28.1",
	"engines": {
		"pnpm": ">=9.4.0",
		"node": "24.x"
	}
}
